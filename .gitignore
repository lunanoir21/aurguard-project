# Rust build output
/target
**/*.rs.bk
*.pdb

# Cargo.lock IS committed — aurguard ships a binary, so a locked, reproducible
# build is intended. (Do not ignore it.)

# npm wrapper
npm/node_modules/
npm/package-lock.json
# Prebuilt binaries are produced by CI, not committed (the launcher
# `npm/bin/aurguard.js` IS committed; the platform binaries are not).
npm/platforms/*/bin/aurguard

# Editor / OS junk
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# Local env / secrets — never commit
.env
.env.*
*.local
